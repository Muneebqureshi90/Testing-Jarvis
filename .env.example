# Secure Blog REST API - Environment Variables Example
# Copy this file to .env and fill in actual values
# DO NOT commit .env to version control!

# Project Configuration
PROJECT_NAME=secure-blog

# Database Configuration
DB_NAME=secure_blog
DB_USERNAME=blog_user
DB_PASSWORD=change-this-to-a-strong-password
DB_ROOT_PASSWORD=change-this-to-a-strong-root-password

# JWT Configuration
# Generate with: openssl rand -base64 32 (minimum 32 bytes, recommended 64 bytes)
APP_JWT_SECRET=your-256-bit-secret-minimum-32-bytes-base64-encoded-here

# Spring Profile
SPRING_PROFILES=dev

# Optional: Server Port (default: 8080)
# SERVER_PORT=8080
